# .env.example — copier vers .env et adapter

# PostgreSQL
DATABASE_URL=postgres://ecommerce:dev_password@postgres:5432/ecommerce

# Kafka
KAFKA_BROKERS=localhost:9094

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=product-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# JWT
JWT_SECRET=dev-secret-change-in-production-please
JWT_ACCESS_TOKEN_DURATION_SECS=900       # 15 min
JWT_REFRESH_TOKEN_DURATION_SECS=604800   # 7 jours

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# gRPC
GRPC_PORT=50051

# HTTP (webhooks Stripe + health-check)
HTTP_PORT=3000

# Notifications
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@ecommerce.dev
APNS_KEY_PATH=./certs/apns-key.p8
APNS_KEY_ID=ABC123
APNS_TEAM_ID=DEF456

# Observabilité
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
RUST_LOG=info,ecommerce=debug